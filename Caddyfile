	# API routes → backend (port 8080)
	handle /auth/* {
		reverse_proxy localhost:8080
	}

	handle /me/* {
		reverse_proxy localhost:8080
	}

	handle /v1/* {
		reverse_proxy localhost:8080
	}

	handle /health {
		reverse_proxy localhost:8080
	}

	# WebSocket transcription → backend
	handle /ws/* {
