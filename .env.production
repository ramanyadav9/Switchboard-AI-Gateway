# Switchboard AI Gateway — Production Config
# Copy this to .env and fill in your values

# Auth (CHANGE THIS — run: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-random-64-char-string

# Database (change this password)
POSTGRES_PASSWORD=switchboard-db-secret

# ─── GPU Server ─────────────────────────────────────────────
# If GPU services run on a DIFFERENT machine, set its IP/hostname here.
# Leave empty to use host.docker.internal (same machine).
GPU_SERVER_HOST=

# vLLM ports (defaults match standard setup)
VLLM_LLM_PORT=8000
VLLM_STT_PORT=8004
VLLM_TTS_PORT=8002
SENSEVOICE_PORT=8006

# vLLM API key (must match what your GPU services expect)
VLLM_API_KEY=vaani-local-key

# Default model name (must match what vLLM serves)
DEFAULT_MODEL=Qwen3-14B

# Public URL for frontend API calls (e.g. http://your-server-ip:41237)
# Leave empty for relative URLs (if frontend is behind same Caddy)
PUBLIC_URL=

# Gateway port (default 41237 — only port exposed publicly)
GATEWAY_PORT=41237
