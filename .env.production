# Switchboard AI Gateway — Production Config
# Copy this to .env and fill in your values

# Auth (CHANGE THIS — run: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-random-64-char-string

# Database (change this password)
POSTGRES_PASSWORD=switchboard-db-secret

# vLLM API key (must match what your GPU services expect)
VLLM_API_KEY=vaani-local-key

# Public URL for frontend API calls (e.g. http://your-server-ip:2341)
# Leave empty for relative URLs (if frontend is behind same Caddy)
PUBLIC_URL=
