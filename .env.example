# App
APP_NAME=Switchboard API
APP_VERSION=1.0.0
DEBUG=true

# JWT Auth
SECRET_KEY=change-this-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (SQLite for local dev; docker-compose overrides for prod)
DATABASE_URL=sqlite:///./switchboard.db

# Redis (local dev; docker-compose overrides for prod)
REDIS_URL=redis://localhost:6379

# vLLM API Key
VLLM_API_KEY=vaani-local-key

# vLLM endpoints (localhost for local dev; host.docker.internal in Docker)
VLLM_LLM_BASE_URL=http://localhost:8000
VLLM_STT_BASE_URL=http://localhost:8004
VLLM_TTS_BASE_URL=http://localhost:8002
SENSEVOICE_BASE_URL=http://localhost:8006

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Public URL for frontend (set to http://your-server:41237 in production)
PUBLIC_URL=

# Gateway port (only port exposed publicly in Docker)
GATEWAY_PORT=41237
