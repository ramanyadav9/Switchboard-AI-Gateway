# App
APP_NAME=Switchboard API
APP_VERSION=1.0.0
DEBUG=true

# JWT Auth
SECRET_KEY=change-this-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (SQLite for local dev; use postgresql://... for Docker/prod)
DATABASE_URL=sqlite:///./switchboard.db

# Redis
REDIS_URL=redis://localhost:6380

# vLLM API Key
VLLM_API_KEY=vaani-local-key

# vLLM endpoints (localhost when backend runs on same server as GPU services)
VLLM_LLM_BASE_URL=http://localhost:8000
VLLM_STT_BASE_URL=http://localhost:8004
VLLM_TTS_BASE_URL=http://localhost:8002
SENSEVOICE_BASE_URL=http://localhost:8006

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Public URL for frontend (set to your-server:2341 in production)
PUBLIC_URL=
