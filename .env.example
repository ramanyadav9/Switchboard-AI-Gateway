# App
APP_NAME=VAANI API
APP_VERSION=0.1.0
DEBUG=true

# JWT Auth
SECRET_KEY=change-this-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (SQLite for local dev; use postgresql://... for Docker/prod)
DATABASE_URL=sqlite:///./vaani.db

# Redis
REDIS_URL=redis://localhost:6379

# LiteLLM
LITELLM_MASTER_KEY=sk-change-this-master-key
LITELLM_BASE_URL=http://localhost:4000

# vLLM API Key (used by LiteLLM to auth with vLLM instances)
VLLM_API_KEY=vaani-local-key

# vLLM endpoints (GPU server)
VLLM_LLM_BASE_URL=http://164.52.194.98:8000
VLLM_STT_BASE_URL=http://164.52.194.98:8004
VLLM_TTS_BASE_URL=http://164.52.194.98:8002

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
